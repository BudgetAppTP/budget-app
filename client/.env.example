# Front-end environment configuration

# Base URL for API calls. Defaults to "/api" when not set.
#VITE_API_URL=

# Google OAuth client ID for the frontend. Provide the Client ID obtained
# from the Google Developer Console here to enable Google login. When
# defined, the login and registration pages will show a "Continue with
# Google" button that uses the Google Identity Services library to
# obtain an ID token and send it to the backend. The value should
# match the `GOOGLE_CLIENT_ID` configured on the backend.
# Example:
#VITE_GOOGLE_CLIENT_ID=1234567890-abc123def456.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=