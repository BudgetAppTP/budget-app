# ------------------------------
# Backend runtime
# ------------------------------
APP_ENV=development
# APP_ENV options used in app config: development | docker-local | production | test
DEBUG=true
SECRET_KEY=change-me
WTF_CSRF_ENABLED=true
HOST=0.0.0.0
PORT=5000
DEFAULT_CURRENCY=EUR
IMPORT_XLSX_PATH=/mnt/data/BugetAppTP.xlsx

# ------------------------------
# Database (Docker + backend)
# ------------------------------
PROD_DOCKER_NETWORK=budget-prod-network
POSTGRES_USER=budget
POSTGRES_PASSWORD=budget
POSTGRES_DB=budget
DATABASE_URL=postgresql+psycopg2://budget:budget@db:5432/budget

# ------------------------------
# Frontend
# ------------------------------
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:5000
FRONTEND_PORT=5173
# For local production compose you likely want: FRONTEND_PORT=80

# ------------------------------
# Production image refs (GHCR)
# ------------------------------
# Required by docker-compose-prod-services.yml / docker-compose-prod-infra.yml
# BACKEND_IMAGE=ghcr.io/<owner>/<repo>/backend:<tag>
# FRONTEND_IMAGE=ghcr.io/<owner>/<repo>/frontend:<tag>
# EXTERNAL_NGINX_IMAGE=ghcr.io/<owner>/<repo>/external-nginx:<tag>

# ------------------------------
# External NGINX Basic Auth (Docker)
# ------------------------------
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me

# ------------------------------
# Optional demo/test auth user
# ------------------------------
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=pass1234
# TEST_USER_PASSWORD_HASH=

# Optional Google OAuth backend audience check.
# Must match VITE_GOOGLE_CLIENT_ID in client/.env when Google login is enabled.
GOOGLE_CLIENT_ID=

# ------------------------------
# Optional SMTP mail delivery
# ------------------------------
SMTP_SERVER=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
